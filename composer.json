{
    "name": "pubvana/profiles",
    "description": "Profile manager for Pubvana",
    "type": "flightphp-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "pubvana",
            "email": "cs@pubvana.net"
        }
    ],
    "require": {
        "php": "^8.1",
        "enlivenapp/flight-school": "^0.3",
        "enlivenapp/flight-shield": "^0.2",
        "enlivenapp/migrations": "^0.2",
        "flightphp/active-record": "^0.7"
    },
    "suggest": {
        "pubvana/admin": "Admin UI for self-service profile page and user edit tab",
        "pubvana/media": "Avatar selection via the media picker widget"
    },
    "autoload": {
        "psr-4": {
            "Pubvana\\Profiles\\": "src/"
        }
    }
}